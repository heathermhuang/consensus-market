{
  "name": "pred",
  "version": "1.0.0",
  "description": "Compliance-first KPI prediction market prototype",
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "build": "npm run contracts:build && npm run frontend:build",
    "contracts:artifacts:clean": "node scripts/clean-hardhat-artifacts.mjs",
    "cf:domain:attach": "node scripts/attach-custom-domain.mjs",
    "cf:runtime:publish": "node scripts/publish-runtime-manifest.mjs",
    "cf:vars:set": "node scripts/set-worker-runtime-vars.mjs",
    "contracts:admin": "node scripts/operator-actions.mjs",
    "contracts:build": "npm run contracts:artifacts:clean && hardhat compile",
    "deploy:cf:prod": "wrangler pages deploy dist --project-name capital-markets",
    "deploy:worker": "node scripts/prepare-worker-assets.mjs && wrangler deploy --config wrangler.worker.jsonc",
    "events:index:prod": "RPC_URL=$(node -e \"const c=require('./config/runtime-manifest.json');process.stdout.write(c.RPC_URL||c.VITE_RPC_URL||'')\" 2>/dev/null) MARKET_ADDRESS=$(node -e \"const c=require('./config/runtime-manifest.json');process.stdout.write(c.MARKET_ADDRESS||c.VITE_MARKET_ADDRESS||'')\" 2>/dev/null) ORACLE_ADDRESS=$(node -e \"const c=require('./config/runtime-manifest.json');process.stdout.write(c.ORACLE_ADDRESS||c.VITE_ORACLE_ADDRESS||'')\" 2>/dev/null) REGISTRY_ADDRESS=$(node -e \"const c=require('./config/runtime-manifest.json');process.stdout.write(c.REGISTRY_ADDRESS||c.VITE_REGISTRY_ADDRESS||'')\" 2>/dev/null) node scripts/index-events.mjs",
    "deploy:staging": "npm run build && wrangler deploy --config wrangler.worker.jsonc --env staging",
    "validate:staging": "VALIDATE_BASE_URL=$(wrangler deployments list --config wrangler.worker.jsonc --env staging 2>/dev/null | grep -o 'https://[^ ]*workers.dev' | head -1) node scripts/validate-production.mjs",
    "demo:deploy": "hardhat run scripts/bootstrap.js",
    "dev:node": "hardhat node",
    "events:index": "node scripts/index-events.mjs",
    "oracle:resolve": "node scripts/oracle-resolve.mjs",
    "bbg:export": "python3 scripts/bloomberg-export.py",
    "bbg:export:dry": "python3 scripts/bloomberg-export.py --dry-run",
    "bbg:sync": "node scripts/sync-bloomberg-data.mjs",
    "bbg:sync:dry": "node scripts/sync-bloomberg-data.mjs --dry-run",
    "bbg:backfill": "python3 scripts/bbg-backfill.py",
    "bbg:backfill:dry": "python3 scripts/bbg-backfill.py --dry-run",
    "bbg:backfill:resume": "python3 scripts/bbg-backfill.py --resume",
    "bbg:build-history": "node scripts/build-market-history.mjs",
    "bbg:universe": "python3 scripts/bbg-universe.py",
    "bbg:universe:discover": "python3 scripts/bbg-universe.py --discover",
    "bbg:universe:stats": "python3 scripts/bbg-universe.py --stats",
    "bbg:global-sync": "python3 scripts/bbg-global-sync.py --resume",
    "bbg:global-sync:kpi": "python3 scripts/bbg-global-sync.py --kpi-only --resume",
    "bbg:global-sync:stats": "python3 scripts/bbg-global-sync.py --stats",
    "bbg:priority": "python3 scripts/bbg-priority-backfill.py",
    "bbg:priority:list": "python3 scripts/bbg-priority-backfill.py --list",
    "bbg:priority:resume": "python3 scripts/bbg-priority-backfill.py --resume",
    "bbg:priority:progress": "python3 scripts/bbg-priority-backfill.py --progress",
    "bbg:discover": "python3 scripts/bbg-discover-fields.py",
    "bbg:discover:dry": "python3 scripts/bbg-discover-fields.py --dry-run",
    "bbg:discover:apply": "python3 scripts/bbg-discover-fields.py --apply",
    "frontend:build": "vite build",
    "frontend:dev": "vite",
    "frontend:preview": "vite preview",
    "markets:sync": "node scripts/sync-seed-markets.mjs",
    "qa:smoke:live": "playwright test qa-evidence/tests/live-smoke.spec.js --reporter=line",
    "validate:prod": "node scripts/validate-production.mjs",
    "validate:prod:live": "VALIDATE_BASE_URL=https://consensusmarket.com node scripts/validate-production.mjs",
    "deploy:prod": "npm run validate:prod && npm run events:index:prod ; npm run deploy:worker && npm run validate:prod:live",
    "runtime:manifest": "node scripts/build-runtime-manifest.mjs",
    "test": "npm run contracts:artifacts:clean && hardhat test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.3",
    "@nomicfoundation/hardhat-mocha": "^3.0.14",
    "@playwright/test": "^1.58.2",
    "@types/chai": "^5.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chai": "^6.2.0",
    "hardhat": "^3.2.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wrangler": "^4.76.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@powfaucet/client": "^2.4.2",
    "@walletconnect/ethereum-provider": "^2.23.8",
    "ethers": "^6.16.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "diff": "8.0.3",
    "serialize-javascript": "7.0.4"
  }
}
